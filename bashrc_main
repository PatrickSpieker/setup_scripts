# ===== CODEX SKILLS =====
# Sync skills from this repo into ~/.codex/skills on every shell start.
# ln -sfn is idempotent, so this is safe to run repeatedly.
sync-skills() {
  for skill in ~/setup_scripts/skills/*/; do
    ln -sfn "$skill" ~/.codex/skills/"$(basename "$skill")" > /dev/null
  done
}
sync-skills
# ===== END CODEX SKILLS =====


# ===== MOAT =====
moat-init() {
  if [[ -f moat.yaml ]]; then
    echo "moat.yaml already exists in this directory."
    return 1
  fi
  cp ~/setup_scripts/templates/moat.yaml ./moat.yaml
  echo "Copied moat.yaml template. Customize as needed, then run: mcl"
}
