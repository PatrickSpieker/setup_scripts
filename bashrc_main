
# ===== BASIC ALIASES =====
# Run this alias to pick up changes to bashrc or bash_profile.
# Uses pushd/popd to preserve your current directory across the source.
alias bashrc='pushd . > /dev/null && source ~/.bash_profile && popd > /dev/null'

alias cp='cp -iv'                           # prompt before overwrite, verbose
alias mv='mv -iv'                           # prompt before overwrite, verbose
alias ln='ln -iv'                           # safer symlink creation
alias mkdir='mkdir -pv'                     # create parents, verbose
alias cd..='cd ../'                         # typo-friendly
alias ..='cd ../'                           # go up 1 level
alias ...='cd ../../'                       # go up 2 levels
alias ~="cd ~"                              # go home
alias c='clear'
alias memes="echo 'this is a good meme'"
alias h='history'
alias cl='claude'
unalias mcl 2>/dev/null
mcl() {
  # Auto-init moat.yaml if missing
  if [[ ! -f moat.yaml ]]; then
    cp ~/setup_scripts/templates/moat.yaml ./moat.yaml
    echo "Created moat.yaml from template."
  fi

  # Ensure repo has at least one commit (needed for worktree branch creation)
  if ! git rev-parse HEAD &>/dev/null; then
    git commit --allow-empty -m "Initial commit"
    echo "Created initial empty commit."
  fi

  local branch="${1:-moat/$(date +%Y%m%d-%H%M%S)}"
  moat claude --worktree "$branch" -- --model=opus
  echo "Cleaning up worktree and container for branch: $branch"
  moat wt clean "$branch" 2>/dev/null
}
mclpr() {
  local pr="$1"
  if [[ -z "$pr" ]]; then
    echo "Usage: mclpr <pr-number>"
    return 1
  fi
  local branch
  branch=$(gh pr view "$pr" --json headRefName -q '.headRefName') || return 1
  git fetch origin "$branch" || return 1
  # If we're on the target branch, switch away so worktree can use it
  if [[ "$(git rev-parse --abbrev-ref HEAD)" == "$branch" ]]; then
    echo "Currently on $branch, switching to default branch..."
    git checkout master 2>/dev/null || git checkout main 2>/dev/null || { echo "Error: could not switch away from $branch"; return 1; }
  fi
  git branch -f "$branch" "origin/$branch" 2>/dev/null || git branch "$branch" "origin/$branch" 2>/dev/null || true
  moat claude --worktree "$branch" -- --model=opus
  echo "Cleaning up worktree and container for branch: $branch"
  moat wt clean "$branch" 2>/dev/null
}
mclb() {
  local branch="$1"
  if [[ -z "$branch" ]]; then
    echo "Usage: mclb <branch>"
    return 1
  fi
  git fetch origin "$branch" || return 1
  # If we're on the target branch, switch away so worktree can use it
  if [[ "$(git rev-parse --abbrev-ref HEAD)" == "$branch" ]]; then
    echo "Currently on $branch, switching to default branch..."
    git checkout master 2>/dev/null || git checkout main 2>/dev/null || { echo "Error: could not switch away from $branch"; return 1; }
  fi
  git branch -f "$branch" "origin/$branch" 2>/dev/null || git branch "$branch" "origin/$branch" 2>/dev/null || true
  moat claude --worktree "$branch" -- --model=opus
  echo "Cleaning up worktree and container for branch: $branch"
  moat wt clean "$branch" 2>/dev/null
}

