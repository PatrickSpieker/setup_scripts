_moat_ensure_default_branch_fresh() {
  # Skip if no remote
  if ! git remote get-url origin &>/dev/null; then
    return 0
  fi

  # Fail on uncommitted changes
  if ! git diff --quiet || ! git diff --cached --quiet; then
    echo "Error: uncommitted changes. Commit or stash first."
    return 1
  fi

  local default_branch
  default_branch=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')
  if [[ -z "$default_branch" ]]; then
    if git rev-parse --verify origin/main &>/dev/null; then
      default_branch="main"
    elif git rev-parse --verify origin/master &>/dev/null; then
      default_branch="master"
    else
      echo "Warning: could not determine default branch, skipping freshness check."
      return 0
    fi
  fi

  echo "Fetching latest $default_branch from origin..."
  git fetch origin "$default_branch" || { echo "Error: failed to fetch origin/$default_branch"; return 1; }
  git checkout "$default_branch" || { echo "Error: failed to checkout $default_branch"; return 1; }
  git pull --ff-only || { echo "Error: $default_branch has diverged from origin. Please resolve manually."; return 1; }
}

_moat_agent_command() {
  local agent="$1"
  case "$agent" in
    claude)
      echo "moat claude -e AI_AGENT=claude"
      ;;
    codex)
      echo "moat codex -e AI_AGENT=codex"
      ;;
    *)
      echo "Unknown agent: $agent" >&2
      return 1
      ;;
  esac
}

_moat_agent_passthrough_args() {
  local agent="$1"
  case "$agent" in
    claude)
      printf '%s\n' "-- --model=opus"
      ;;
    codex)
      printf '%s\n' "-- --model=gpt-5-codex"
      ;;
    *)
      echo "Unknown agent: $agent" >&2
      return 1
      ;;
  esac
}

_moat_launch() {
  local agent="$1"
  shift

  local mount=false
  local args=()
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -m) mount=true; shift ;;
      *) args+=("$1"); shift ;;
    esac
  done

  if ! git rev-parse --is-inside-work-tree &>/dev/null; then
    git init
    echo "Initialized git repo."
  fi

  if [[ ! -f moat.yaml ]]; then
    cp ~/setup_scripts/templates/moat.yaml ./moat.yaml
    echo "Created moat.yaml from template."
  fi

  _moat_ensure_default_branch_fresh || return 1

  local moat_cmd
  moat_cmd=$(_moat_agent_command "$agent") || return 1
  local passthrough
  passthrough=$(_moat_agent_passthrough_args "$agent") || return 1

  if [[ "$mount" == true ]]; then
    local branch="${args[0]:-moat/$(date +%Y%m%d-%H%M%S)}"
    git checkout -b "$branch"
    eval "$moat_cmd $passthrough"
  else
    if ! git rev-parse HEAD &>/dev/null; then
      git add -A
      git commit -m "Initial commit"
      echo "Created initial commit."
    fi

    local branch="${args[0]:-moat/$(date +%Y%m%d-%H%M%S)}"
    eval "$moat_cmd --worktree \"$branch\" $passthrough"
    echo "Cleaning up worktree and container for branch: $branch"
    moat wt clean "$branch" 2>/dev/null
  fi
}

_moat_resume_pr() {
  local agent="$1"
  local pr="$2"
  if [[ -z "$pr" ]]; then
    echo "Usage: m${agent:0:1}o?pr <pr-number>"
    return 1
  fi
  _moat_ensure_default_branch_fresh || return 1

  local branch
  branch=$(gh pr view "$pr" --json headRefName -q '.headRefName') || return 1
  _moat_resume_branch "$agent" "$branch"
}

_moat_resume_branch() {
  local agent="$1"
  local branch="$2"
  if [[ -z "$branch" ]]; then
    echo "Missing branch name"
    return 1
  fi
  git fetch origin "$branch" || return 1
  if [[ "$(git rev-parse --abbrev-ref HEAD)" == "$branch" ]]; then
    echo "Currently on $branch, switching to default branch..."
    git checkout master 2>/dev/null || git checkout main 2>/dev/null || { echo "Error: could not switch away from $branch"; return 1; }
  fi
  git branch -f "$branch" "origin/$branch" 2>/dev/null || git branch "$branch" "origin/$branch" 2>/dev/null || true

  local moat_cmd
  moat_cmd=$(_moat_agent_command "$agent") || return 1
  local passthrough
  passthrough=$(_moat_agent_passthrough_args "$agent") || return 1
  eval "$moat_cmd --worktree \"$branch\" $passthrough"
  echo "Cleaning up worktree and container for branch: $branch"
  moat wt clean "$branch" 2>/dev/null
}

unalias mcl 2>/dev/null
mcl() {
  _moat_launch claude "$@"
}
mclpr() {
  local pr="$1"
  if [[ -z "$pr" ]]; then
    echo "Usage: mclpr <pr-number>"
    return 1
  fi
  _moat_resume_pr claude "$pr"
}
mclb() {
  local branch="$1"
  if [[ -z "$branch" ]]; then
    echo "Usage: mclb <branch>"
    return 1
  fi
  _moat_resume_branch claude "$branch"
}

unalias mco 2>/dev/null
mco() {
  _moat_launch codex "$@"
}
mcopr() {
  local pr="$1"
  if [[ -z "$pr" ]]; then
    echo "Usage: mcopr <pr-number>"
    return 1
  fi
  _moat_resume_pr codex "$pr"
}
mcob() {
  local branch="$1"
  if [[ -z "$branch" ]]; then
    echo "Usage: mcob <branch>"
    return 1
  fi
  _moat_resume_branch codex "$branch"
}

