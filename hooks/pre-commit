#!/usr/bin/env bash
# Repo-specific pre-commit hook: runs the lint suite via test_runner.sh.
# Repos using the shared hooksPath that don't have a test_runner.sh will
# fail on commit — add one or replace this hook with a no-op.
set -euo pipefail
REPO_DIR="$(git rev-parse --show-toplevel)"
"$REPO_DIR/test_runner.sh" lint
