#!/usr/bin/env bash
if [[ "$CLAUDECODE" == "1" ]]; then
  while read -r _ _ remote_ref _; do
    if [[ "$remote_ref" =~ refs/heads/(main|master)$ ]]; then
      echo "ERROR: Pushing to main/master is blocked for Claude Code."
      exit 1
    fi
  done
fi

# Skip when running inside test harness to avoid recursion
if [[ -z "${SKIP_HOOK_TESTS:-}" ]]; then
  REPO_DIR="$(git rev-parse --show-toplevel)"
  "$REPO_DIR/test_runner.sh" test
fi
