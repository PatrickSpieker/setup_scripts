{
  "effortLevel": "max",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "/tmp/setup-scripts/hooks/copy-plan.sh"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "linear": {
      "transport": "http",
      "url": "https://mcp.linear.app/mcp"
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp"]
    }
  },
  "model": "opus"
}
