{
  "extraKnownMarketplaces": {
    "render-plugins": {
      "source": {
        "source": "github",
        "repo": "render-oss/skills"
      }
    }
  },
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "mcpServers": {
    "linear": {
      "transport": "http",
      "url": "https://mcp.linear.app/mcp"
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp"
      ]
    }
  },
  "enabledPlugins": {
    "render@render-plugins": true
  }
}
